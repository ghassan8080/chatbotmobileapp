  {
    "id": "TC001",
    "title": "Successful login routes user to Products screen",
    "description": "Verifies a user can log in with valid credentials and land on the Products screen.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"Login\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"{{LOGIN_USER}}\" into the login input field"
      },
      {
        "type": "action",
        "description": "Fill \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click \"Login\" button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Products\" is visible"
      }
    ]
  },
