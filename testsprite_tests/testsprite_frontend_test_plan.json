[
  {
    "id": "TC001",
    "title": "Successful login redirects user to Products screen",
    "description": "Verifies a user can log in with valid credentials and is taken to the Products screen.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"Login\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the login input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Products\" is visible"
      }
    ]
  },
  {
